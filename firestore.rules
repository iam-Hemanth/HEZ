rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidBookmark(data) {
      return data.keys().hasAll(['id', 'title', 'ownerId', 'createdAt'])
        && data.id is number
        && data.title is string && data.title.size() <= 200
        && data.ownerId == request.auth.uid
        && data.createdAt == request.time
        && (data.get('overview', '') is string && data.get('overview', '').size() <= 5000)
        && (data.get('backdrop_path', '') is string && data.get('backdrop_path', '').size() <= 500)
        && (data.get('poster_path', '') is string && data.get('poster_path', '').size() <= 500)
        && (data.get('release_date', '') is string && data.get('release_date', '').size() <= 100)
        && data.get('vote_average', 0) is number
        && data.get('genre_ids', []) is list && data.get('genre_ids', []).size() <= 20
        && (data.get('media_type', 'movie') is string && data.get('media_type', 'movie').size() <= 20);
    }

    match /users/{userId}/bookmarks/{bookmarkId} {
      allow get: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidId(bookmarkId);
      allow list: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
      
      allow create: if isSignedIn() 
                    && isValidId(userId)
                    && userId == request.auth.uid
                    && isValidId(bookmarkId)
                    && isValidBookmark(incoming());
                    
      allow delete: if isSignedIn()
                    && isValidId(userId)
                    && userId == request.auth.uid
                    && isValidId(bookmarkId);
    }
  }
}
